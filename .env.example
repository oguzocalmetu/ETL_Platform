# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=dataflow
POSTGRES_USER=dataflow
POSTGRES_PASSWORD=dataflow_secret_change_me
DATABASE_URL=postgresql+asyncpg://dataflow:dataflow_secret_change_me@postgres:5432/dataflow
DATABASE_URL_SYNC=postgresql://dataflow:dataflow_secret_change_me@postgres:5432/dataflow

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_32_CHARS_MINIMUM_SECRET_KEY

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY_BASE64

# ── Default Admin ─────────────────────────────────────────────────────────────
FIRST_ADMIN_EMAIL=admin@dataflow.local
FIRST_ADMIN_PASSWORD=Admin123!

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost"]
