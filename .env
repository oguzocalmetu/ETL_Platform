# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_ENCRYPTION_KEY=YWJjZGVmZ2hpamtsbW5vcHFyc3R1dnd4eXoxMjM0NTY=

# ── Default Admin ─────────────────────────────────────────────────────────────
FIRST_ADMIN_EMAIL=admin@dataflow.local
FIRST_ADMIN_PASSWORD=Admin123!

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
ALLOWED_ORIGINS=["http://localhost","http://localhost:3000","http://localhost:5173","http://localhost:8000"]
